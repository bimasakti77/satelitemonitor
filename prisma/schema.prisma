generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMINISTRATOR
  OPERATOR_UKE
  EXECUTIVE
}

enum ServiceScope {
  INTERNAL
  EKSTERNAL
}

enum IntegrationReadiness {
  Q1
  Q2
  Q3
  NOT_READY
}

enum HistoryAction {
  CREATED
  UPDATED
  DELETED
}

enum ImportStatus {
  PREVIEW
  COMMITTED
  ROLLED_BACK
  FAILED
}

enum FunctionApiStatus {
  BELUM_TERSEDIA
  ON_PROGRESS
  SUDAH_TERSEDIA
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole
  ukeId        String?
  uke          Uke?     @relation(fields: [ukeId], references: [id])
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  serviceHistories ServiceHistory[]
  auditLogs        AuditLog[]
  imports          Import[]
}

model Uke {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users    User[]
  services Service[]
}

model Application {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  vendor      String?
  /// true jika ada Service dengan namaAplikasi yang sama dan scope EKSTERNAL
  isPublic    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id                  String               @id @default(cuid())
  externalId          String?              @unique
  kelompokLayanan     String
  jenisLayanan        String
  tahunPekerjaan      Int
  scope               ServiceScope
  tipeLayananInternal String?
  sudahSuperApps      Boolean              @default(false)
  kesiapanIntegrasi   IntegrationReadiness @default(NOT_READY)
  namaAplikasi        String?
  detailAplikasi      String?              @db.Text
  ukeId               String?
  uke                 Uke?                 @relation(fields: [ukeId], references: [id])
  isDeleted           Boolean              @default(false)
  deletedAt           DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  fungsi        ServiceFunction[]
  histories     ServiceHistory[]
  notifications Notification[]

  @@index([ukeId])
  @@index([kelompokLayanan])
  @@index([tahunPekerjaan])
  @@index([jenisLayanan])
  @@index([isDeleted])
}

model ServiceFunction {
  id        String   @id @default(cuid())
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  nama      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apis ServiceFunctionApi[]

  @@index([serviceId])
}

model ServiceFunctionApi {
  id         String            @id @default(cuid())
  functionId String
  function   ServiceFunction   @relation(fields: [functionId], references: [id], onDelete: Cascade)
  nama       String
  endpoint   String?
  status     FunctionApiStatus @default(BELUM_TERSEDIA)
  catatan    String?           @db.Text
  sortOrder  Int               @default(0)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([functionId])
  @@index([status])
}

model ServiceHistory {
  id            String        @id @default(cuid())
  serviceId     String
  service       Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  action        HistoryAction
  fieldName     String?
  previousValue String?       @db.Text
  newValue      String?       @db.Text
  snapshot      Json?
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  createdAt     DateTime      @default(now())

  @@index([serviceId])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([entity])
}

model Import {
  id               String       @id @default(cuid())
  filename         String
  status           ImportStatus @default(PREVIEW)
  totalRows        Int          @default(0)
  insertedCount    Int          @default(0)
  updatedCount     Int          @default(0)
  skippedCount     Int          @default(0)
  errorCount       Int          @default(0)
  validationReport Json?
  snapshot         Json?
  userId           String
  user             User         @relation(fields: [userId], references: [id])
  committedAt      DateTime?
  rolledBackAt     DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

/// ========== Project Dossier ==========

enum DomainProgressStatus {
  VERY_HIGH
  NEEDS_STRENGTHENING
  ACHIEVED
}

enum DossierTeamType {
  STEERING
  EXECUTING
}

enum DocumentCompleteness {
  NOT_AVAILABLE
  DRAFT
  COMPLETE
  VERIFIED
}

model ProjectProfile {
  id                  String   @id @default(cuid())
  title               String
  subtitle            String?
  background          String?  @db.Text
  baselineYear        Int      @default(2026)
  targetYear          Int      @default(2028)
  targetMaturityLevel Int      @default(4)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model DossierDomain {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assessments DossierDomainAssessment[]
}

model DossierDomainAssessment {
  id            String               @id @default(cuid())
  domainId      String
  domain        DossierDomain        @relation(fields: [domainId], references: [id], onDelete: Cascade)
  year          Int
  maturityLevel Int                  @default(0)
  status        DomainProgressStatus @default(NEEDS_STRENGTHENING)
  remarks       String?              @db.Text
  targetText    String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  evidences DossierDomainLevelEvidence[]

  @@unique([domainId, year])
  @@index([year])
}

/// Dokumen dukungan per level kematangan (1–5) pada assessment domain.
model DossierDomainLevelEvidence {
  id           String                   @id @default(cuid())
  assessmentId String
  assessment   DossierDomainAssessment  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  level        Int
  title        String
  notes        String?                  @db.Text
  filename     String
  originalName String
  mimeType     String
  sizeBytes    Int
  storagePath  String
  isActive     Boolean                  @default(true)
  uploadedById String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  @@index([assessmentId, level])
  @@index([isActive])
}

model DossierIndicator {
  id                String   @id @default(cuid())
  name              String
  baselineCondition String   @db.Text
  targetCondition   String   @db.Text
  sortOrder         Int      @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model DossierRoadmapItem {
  id          String   @id @default(cuid())
  year        Int
  title       String
  description String?  @db.Text
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([year])
}

model DossierTeamMember {
  id        String         @id @default(cuid())
  name      String
  roleTitle String
  unit      String?
  teamType  DossierTeamType
  sortOrder Int            @default(0)
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([teamType])
}

model DossierDocument {
  id           String               @id @default(cuid())
  category     String
  title        String
  description  String?              @db.Text
  filename     String?
  mimeType     String?
  sizeBytes    Int?
  storagePath  String?
  completeness DocumentCompleteness @default(NOT_AVAILABLE)
  notes        String?              @db.Text
  sortOrder    Int                  @default(0)
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([category])
  @@index([completeness])
}
